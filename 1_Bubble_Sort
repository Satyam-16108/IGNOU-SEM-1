#include <iostream>
using namespace std;

int main() {
    int n;

    cout << "Enter number of elements: ";
    cin >> n;

    int arr[n];

    cout << "Enter elements:\n";
    for(int i = 0; i < n; i++) {
        cin >> arr[i];
    }

    int comparisons = 0;
    int swaps = 0;
    int outerLoopCount = 0;
    int innerLoopCount = 0;

    // Bubble Sort
    for(int i = 0; i < n - 1; i++) {
        outerLoopCount++;

        for(int j = 0; j < n - i - 1; j++) {
            innerLoopCount++;
            comparisons++;

            if(arr[j] > arr[j + 1]) {
                // swap
                int temp = arr[j];
                arr[j] = arr[j + 1];
                arr[j + 1] = temp;

                swaps++;
            }
        }
    }

    // Output sorted array
    cout << "\nSorted array:\n";
    for(int i = 0; i < n; i++) {
        cout << arr[i] << " ";
    }

    // Display stats
    cout << "\n\nStatistics:\n";
    cout << "Comparisons: " << comparisons << endl;
    cout << "Swaps (Exchanges): " << swaps << endl;
    cout << "Outer loop iterations: " << outerLoopCount << endl;
    cout << "Inner loop iterations: " << innerLoopCount << endl;

    return 0;
}
